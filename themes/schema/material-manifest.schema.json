{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phx://schemas/material-manifest-0.2.json",
  "title": "PHX Material Manifest 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "author",
    "version",
    "engine",
    "status",
    "fallback",
    "styles",
    "assetsBudgetKb",
    "capabilities",
    "network",
    "scripts",
    "componentContract"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,39}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64
    },
    "author": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$"
    },
    "engine": {
      "enum": [
        "0.3.x",
        "0.7.x"
      ]
    },
    "status": {
      "enum": [
        "stable",
        "beta",
        "alpha",
        "community"
      ]
    },
    "fallback": {
      "type": "boolean"
    },
    "styles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+\\.css$"
      }
    },
    "assetsBudgetKb": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "visual-tokens",
          "components",
          "timer",
          "icons",
          "motion",
          "sound-theme",
          "component-contract"
        ]
      }
    },
    "network": {
      "const": "forbidden"
    },
    "scripts": {
      "const": "forbidden"
    },
    "componentContract": {
      "const": "0.1.x"
    }
  }
}
